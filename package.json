{
  "private": true,
  "scripts": {
    "build": "pnpm -r --filter @keepit/schemas build && pnpm -r --filter !@keepit/schemas build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "prisma",
      "esbuild",
      "msgpackr-extract",
      "unrs-resolver"
    ]
  }
}
