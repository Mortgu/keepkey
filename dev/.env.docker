# PostgreSQL
POSTGRES_USER=keepit
POSTGRES_PASSWORD=keepit
POSTGRES_DB=keepit

# App
BETTER_AUTH_SECRET=change-me-to-a-random-secret
BETTER_AUTH_URL=http://localhost:3000
DATABASE_URL=postgresql://keepit:keepit@postgres:5432/keepit
REDIS_URL=redis://redis:6379
PORT=3000
NODE_ENV=production
CORS_ORIGIN=http://localhost:3000

# NextCloud (configure for your instance)
NEXTCLOUD_URL=http://nextcloud:8080/
NEXTCLOUD_USER=admin
NEXTCLOUD_PASSWORD=change-me
NEXTCLOUD_OFFER_PATH=/Vertrieb/AG_Angebotsausgang/GJ2026
NEXTCLOUD_OFFER_PDF_PATH=/Vertrieb/AG_Angebotsausgang/GJ2026/PDF
NEXTCLOUD_OFFER_ORIGINAL_PATH=/Vertrieb/AG_Angebotsausgang/GJ2026/Original
NEXTCLOUD_ORDER_PDF_PATH=/
NEXTCLOUD_ORDER_ORIGINAL_PATH=/

# Templates and output
TEMPLATES_DIR=assets/templates
OUTPUT_DIR=generated