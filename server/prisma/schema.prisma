generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  salutation    String
  firstName     String
  lastName      String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  role           String?
  banned         Boolean?        @default(false)
  banReason      String?
  banExpires     DateTime?
  shoppingCarts  ShoppingCart[]
  orders         Order[]
  address        Address?
  contactPersons ContactPerson[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime?

  @@index([identifier])
  @@map("verification")
}

model Product {
  id   String @id @default(uuid())
  name String @unique

  description String?
  link        String?

  published Boolean @default(false)

  shoppingCarts  ShoppingCart[]
  productPricing ProductPricing[]
  orderPositions OrderPosition[]

  createdAt DateTime? @default(now())
  updatedAt DateTime?

  @@index([name])
  @@map("product")
}

model Contract {
  id String @id @default(uuid())

  name String

  productPricing ProductPricing[]
  orderPositions OrderPosition[]
  shoppingCard   ShoppingCart[]

  createdAt DateTime? @default(now())

  @@map("contract")
}

model ProductPricing {
  id String @id @default(uuid())

  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  contractId String

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  min_quantity Int
  max_quantity Int? @default(0)

  duration Int? @default(1)

  price Float

  @@map("pricing")
}

model ShoppingCart {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  product   Product @relation(fields: [productId], references: [id])
  productId String

  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String

  duration Int
  quantity Int

  price Float? @default(0)

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now())

  @@unique([userId, productId, contractId, duration])
  @@map("cart")
}

model Order {
  id String @id @default(uuid())

  user   User   @relation(fields: [userId], references: [id])
  userId String

  orderPositions OrderPosition[]
  documentJobs   DocumentJob[]

  createdAt DateTime? @default(now())
  updatedAt DateTime? @default(now())

  @@map("order")
}

model DocumentJob {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type      String
  status    String   @default("pending")
  error     String?
  jobId     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([status])
  @@map("document_job")
}

model OrderPosition {
  id String @id @default(uuid())

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  product   Product @relation(fields: [productId], references: [id])
  productId String

  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String

  duration Int
  quantity Int

  priceAtPurchase Float
  currency        String @default("EUR")

  createdAt DateTime? @default(now())

  @@map("order_position")
}

model Address {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  street String?
  city   String?
  plz    String?
  phone  String?

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@map("address")
}

model ContactPerson {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  salutation String
  firstName  String
  lastName   String
  email      String?

  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@index([userId])
  @@map("contact_person")
}
