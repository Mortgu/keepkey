model Offer {
  id String @id @default(uuid())

  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  supplierId String?

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  customerContactPerson ContactPerson @relation(fields: [contactPersonId], references: [id])
  contactPersonId       String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  language Language @default(DE)

  quoteId     String // quoteId / voucherId
  paymentTerm String

  featureComparison Boolean @default(false)

  date        DateTime  @default(now())
  validUntil  DateTime?
  requestFrom DateTime?

  offerFlatRates OfferFlatRate[]
  offerPositions OfferPosition[]
  offerDocuments OfferDocument[]
  revisions      OfferRevision[]

  orders Order?

  net_amount Int

  version Int @default(1)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("offer")
}

model OfferRevision {
  id String @id @default(uuid())

  version  Int
  snapshot Json

  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId String

  changedBy   User   @relation(fields: [changedById], references: [id])
  changedById String

  createdAt DateTime @default(now())

  @@map("offer_revision")
}

model OfferPosition {
  id String @id @default(uuid())

  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId String

  product   Product @relation(fields: [productId], references: [id])
  productId String

  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String

  duration_months Int
  free_months     Int @default(0)
  quantity        Int

  optional Boolean? @default(false)

  eur_user_month Int
  total_cents    Int

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("offer_position")
}

model OfferFlatRate {
  id String @id @default(uuid())

  flatRate   FlatRate @relation(fields: [flatRateId], references: [id])
  flatRateId String

  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId String

  quantity    Int
  total_cents Int

  @@map("offer_flat_rate")
}

model OfferDocument {
  id String @id @default(cuid())

  displayName String?
  version     Int            @default(0)
  status      DocumentStatus
  isCurrent   Boolean        @default(false)

  error String?

  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId String

  pdf   Document? @relation(name: "offerPdf", fields: [pdfId], references: [id], onDelete: Cascade)
  pdfId String?   @unique

  docx   Document? @relation(name: "offerDocx", fields: [docxId], references: [id], onDelete: Cascade)
  docxId String?   @unique

  task   Task   @relation(fields: [taskId], references: [id])
  taskId String

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("offer_document")
}
