model Offer {
  id String @id @default(uuid())

  supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  supplierId String?

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  customerContactPerson ContactPerson @relation(fields: [contactPersonId], references: [id])
  contactPersonId       String

  user   User   @relation(fields: [userId], references: [id])
  userId String

  language Language @default(DE)

  quoteId         String // quoteId / voucherId
  /// @openapi.ignore
  documentVersion Int    @default(0)
  paymentTerm     String

  featureComparison Boolean  @default(false)
  toCompare         String[]

  date        DateTime  @default(now())
  validUntil  DateTime?
  requestFrom DateTime?

  offerFlatRates OfferFlatRate[]
  offerPositions OfferPosition[]
  offerDocuments OfferDocument[]
  revisions      OfferRevision[]

  orders Order?

  net_amount Int

  version Int @default(1)

  createdAt      DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime        @updatedAt @db.Timestamptz(6)
  offerDiscounts OfferDiscount[]

  @@map("offer")
}

model OfferRevision {
  id String @id @default(uuid())

  version         Int
  snapshotVersion Int  @default(1)
  snapshot        Json

  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId String

  changedBy   User   @relation(fields: [changedById], references: [id])
  changedById String

  createdAt DateTime @default(now())

  @@unique([offerId, version])
  @@map("offer_revision")
}

model OfferPosition {
  id String @id @default(uuid())

  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId String

  product   Product @relation(fields: [productId], references: [id])
  productId String

  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String

  duration_months Int
  free_months     Int @default(0)
  quantity        Int

  optional Boolean? @default(false)

  eur_user_month Int
  total_cents    Int
  discount_cents Int @default(0)

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("offer_position")
}

model OfferFlatRate {
  id String @id @default(uuid())

  flatRate   FlatRate @relation(fields: [flatRateId], references: [id])
  flatRateId String

  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId String

  quantity    Int
  total_cents Int

  @@map("offer_flat_rate")
}

model OfferDocument {
  id String @id @default(cuid())

  displayName   String?
  version       Int            @default(0)
  sourceVersion Int?
  status        DocumentStatus
  isCurrent     Boolean        @default(false)

  error       String?
  /// @openapi.ignore
  uploadToken String?

  offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId String

  artifacts DocumentArtifact[] @relation("OfferDocumentArtifacts")

  task   Task   @relation(fields: [taskId], references: [id])
  taskId String @unique

  createdAt DateTime  @default(now()) @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @db.Timestamptz(6)
  deletedAt DateTime? @db.Timestamptz(6)

  @@unique([offerId, version])
  @@map("offer_document")
}

model OfferDiscount {
  id String @id @default(cuid())

  offer   Offer  @relation(fields: [offerId], references: [id])
  offerId String

  title       String
  description String?

  amount_cents Int

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("offer_discount")
}
