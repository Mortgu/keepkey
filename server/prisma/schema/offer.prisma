model Offer {
    id String @id @default(uuid())

    supplier   Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
    supplierId String?

    customer   Customer @relation(fields: [customerId], references: [id])
    customerId String

    customerContactPerson ContactPerson @relation(fields: [contactPersonId], references: [id])
    contactPersonId       String

    user   User   @relation(fields: [userId], references: [id])
    userId String

    voucherId   String
    paymentTerm String

    date        DateTime  @default(now())
    validUntil  DateTime?
    requestFrom DateTime?

    offerFlatRates OfferFlatRate[]
    offerPositions OfferPosition[]
    order          Order?

    // New
    documents Document[]
    tasks     Task[]

    // (in cent)
    net_amount   Int // Der reine Warenwert (netto) 
    tax_rate     Int // Der angewendete Prozentsatz (e.g 19.00)
    tax_amount   Int // absolute Steuerbetrag
    total_amount Int // Finale Brutto Betrag

    createdAt DateTime @default(now())
    updatedAt DateTime @default(now())

    @@map("offer")
}

model OfferPosition {
    id String @id @default(uuid())

    offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
    offerId String

    product   Product @relation(fields: [productId], references: [id])
    productId String

    contract   Contract @relation(fields: [contractId], references: [id])
    contractId String

    duration_months Int
    quantity        Int

    optional Boolean? @default(false)

    total_cents Int
    tax_rate    Int

    createdAt DateTime? @default(now())
    updatedAt DateTime? @default(now())

    @@map("offer_position")
}

model OfferFlatRate {
    id String @id @default(uuid())

    flatRate   FlatRate @relation(fields: [flatRateId], references: [id])
    flatRateId String

    offer   Offer  @relation(fields: [offerId], references: [id], onDelete: Cascade)
    offerId String

    quantity    Int
    total_cents Int

    @@map("offer_flat_rate")
}
