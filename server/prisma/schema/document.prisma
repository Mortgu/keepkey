enum DocumentStatus {
  UPLOADED
  UPLOADING
  GENERATED
  PROCESSING
  PENDING
  FAILED
}

model Document {
  id String @id @default(cuid())

  version     Int
  displayName String?

  pdfReady  Boolean @default(false)
  docxReady Boolean @default(false)

  status    DocumentStatus @default(PENDING)
  isCurrent Boolean

  offer   Offer?  @relation(fields: [offerId], references: [id])
  offerId String?

  order   Order?  @relation(fields: [orderId], references: [id])
  orderId String?

  taskId String? @unique
  task   Task?   @relation("DocumentTask", fields: [taskId], references: [id])

  createdAt DateTime @default(now())

  @@unique([offerId, version])
  @@map("document")
}

enum TaskStatus {
  COMPLETED
  RUNNING
  PENDING
  FAILED
}

enum TaskType {
  OFFER
  ORDER
  RENEWAL
  RESERVATION
  UPLOAD
}

model Task {
  id    String  @id @default(cuid())
  jobId String?

  status TaskStatus @default(PENDING)
  type   TaskType

  error String?

  document         Document? @relation("DocumentTask")
  offerReservation Offer?    @relation("OfferReservationTask")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("task")
}
