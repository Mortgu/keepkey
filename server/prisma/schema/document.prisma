enum DocumentStatus {
  UPLOADED
  UPLOADING
  GENERATED
  PROCESSING
  PENDING
  FAILED
}

model Document {
  id String @id @default(cuid())

  version     Int
  displayName String?

  pdfReady  Boolean @default(false)
  docxReady Boolean @default(false)

  status    DocumentStatus @default(PENDING)
  isCurrent Boolean

  offer   Offer?  @relation(fields: [offerId], references: [id])
  offerId String?

  order   Order?  @relation(fields: [orderId], references: [id])
  orderId String?

  createdAt DateTime @default(now())

  @@unique([offerId, version])
  @@map("document")
}

enum TaskStatus {
  COMPLETED
  RUNNING
  PENDING
  FAILED
}

enum TaskType {
  OFFER
  ORDER
  RENEWAL
  RESERVATION
  UPLOAD
}

model Task {
  id    String  @id @default(cuid())
  jobId String? // BullMQ job id

  status TaskStatus @default(PENDING)
  type   TaskType

  offer   Offer?  @relation(fields: [offerId], references: [id])
  offerId String?

  order   Order?  @relation(fields: [orderId], references: [id])
  orderId String?

  error String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())

  @@map("task")
}
