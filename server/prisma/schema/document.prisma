enum DocumentStatus {
  PENDING
  PROCESSING
  GENERATED
  UPLOADING
  UPLOADED
  FAILED
}

enum DocumentFormat {
  PDF
  DOCX
}

model Document {
  id String @id @default(cuid())

  objectKey String         @unique
  format    DocumentFormat

  size   Int?
  sha256 String?

  uploadedAt DateTime? @db.Timestamptz(6)
  remotePath String?   @unique
  remoteEtag String?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  offerPdfDocument  OfferDocument? @relation("offerPdf")
  offerDocxDocument OfferDocument? @relation("offerDocx")

  orderPdfDocument  OrderDocument? @relation("orderPdf")
  orderDocxDocument OrderDocument? @relation("orderDocx")

  @@map("document")
}
