enum DocumentStatus {
  PENDING
  PROCESSING
  GENERATED
  UPLOADING
  UPLOADED
  FAILED
}

enum DocumentFormat {
  PDF
  DOCX
  RESERVED
}

model Document {
  id String @id @default(cuid())

  displayName String?
  format      DocumentFormat
  status      DocumentStatus @default(PENDING)
  path        String?

  taskId String? @unique
  task   Task?   @relation("DocumentTask", fields: [taskId], references: [id])

  offerDocument OfferDocument?
  orderDocument OrderDocument?

  createdAt DateTime @default(now())

  @@map("document")
}
