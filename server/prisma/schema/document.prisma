enum DocumentStatus {
  PENDING
  PROCESSING
  GENERATED
  UPLOADING
  UPLOADED
  FAILED
}

enum DocumentFormat {
  PDF
  DOCX
}

model Document {
  id String @id @default(cuid())

  filename String // generated/xdawdawd.pdf
  basename String // xdawdawd.pdf
  path     String // generated
  format   DocumentFormat // PDF || DOCX

  size Int?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  offerPdfDocument  OfferDocument? @relation("offerPdf")
  offerDocxDocument OfferDocument? @relation("offerDocx")

  orderPdfDocument  OrderDocument? @relation("orderPdf")
  orderDocxDocument OrderDocument? @relation("orderDocx")

  @@unique([filename])
  @@map("document")
}
