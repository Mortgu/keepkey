enum DocumentStatus {
  PENDING
  PROCESSING
  GENERATED
  UPLOADING
  UPLOADED
  FAILED
}

enum DocumentFormat {
  PDF
  DOCX
}

model DocumentArtifact {
  id String @id @default(cuid())

  objectKey String         @unique
  format    DocumentFormat

  size   Int?
  sha256 String?

  uploadedAt DateTime? @db.Timestamptz(6)
  remotePath String?   @unique
  remoteEtag String?

  offerDocument   OfferDocument? @relation("OfferDocumentArtifacts", fields: [offerDocumentId], references: [id], onDelete: Cascade)
  offerDocumentId String?

  orderDocument   OrderDocument? @relation("OrderDocumentArtifacts", fields: [orderDocumentId], references: [id], onDelete: Cascade)
  orderDocumentId String?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([offerDocumentId, format])
  @@unique([orderDocumentId, format])
  @@map("document")
}
