model TariffGroup {
  id String @id @default(cuid())

  products TariffGroupProduct[]
  tariffs  Tariff[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("tariff_group")
}

model TariffGroupProduct {
  id String @id @default(cuid())

  tariffGroup   TariffGroup @relation(fields: [tariffGroupId], references: [id], onDelete: Cascade)
  tariffGroupId String

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String  @unique

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("tariff_group_product")
}

model Tariff {
  id String @id @default(cuid())

  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String

  tariffGroup   TariffGroup @relation(fields: [tariffGroupId], references: [id], onDelete: Cascade)
  tariffGroupId String

  rows    TariffRow[]
  columns TariffColumn[]
  cells   TariffCell[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([tariffGroupId, contractId])
  @@map("tariff")
}

model TariffRow {
  id String @id @default(cuid())

  tariff   Tariff @relation(fields: [tariffId], references: [id], onDelete: Cascade)
  tariffId String

  min_quantity Int
  max_quantity Int?

  order Int

  cells TariffCell[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([tariffId, order])
  @@map("tariff_row")
}

model TariffColumn {
  id String @id @default(cuid())

  tariff   Tariff @relation(fields: [tariffId], references: [id], onDelete: Cascade)
  tariffId String

  duration Int
  order    Int

  cells TariffCell[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([tariffId, order])
  @@map("tariff_column")
}

model TariffCell {
  id String @id @default(cuid())

  tariff   Tariff @relation(fields: [tariffId], references: [id], onDelete: Cascade)
  tariffId String

  row   TariffRow @relation(fields: [rowId], references: [id], onDelete: Cascade)
  rowId String

  column   TariffColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  columnId String

  default_cells  TariffCellDefault[]
  customer_cells TariffCellCustomer[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([rowId, columnId])
  @@map("tariff_cell")
}

model TariffCellDefault {
  id String @id @default(cuid())

  cell   TariffCell @relation(fields: [cellId], references: [id], onDelete: Cascade)
  cellId String     @unique

  price Int

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("tariff_cell_default")
}

model TariffCellCustomer {
  id String @id @default(cuid())

  cell   TariffCell @relation(fields: [cellId], references: [id], onDelete: Cascade)
  cellId String

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  customerId String

  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String?

  price Int

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([cellId, customerId, productId])
  @@map("tariff_cell_customer")
}

model TariffHistory {
  id String @id @default(cuid())

  productId  String
  contractId String

  version  Int
  snapshot Json

  createdAt DateTime @default(now()) @db.Timestamptz(6)

  @@unique([productId, contractId, version])
  @@map("tariff_history")
}
