model Tariff {
  id String @id @default(cuid())

  product   Product @relation(fields: [productId], references: [id])
  productId String

  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String

  terms Int[]       @default([12, 24, 36])
  rows  TariffRow[]

  validFrom DateTime  @default(now()) @db.Timestamptz(6)
  validTo   DateTime?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("tariff")
}

model TariffRow {
  id String @id @default(cuid())

  tariff   Tariff @relation(fields: [tariffId], references: [id], onDelete: Cascade)
  tariffId String

  min_quantity Int
  max_quantity Int
  order        Int @default(0)

  cells TariffCell[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("tariff_row")
}

model TariffCell {
  id String @id @default(cuid())

  row   TariffRow @relation(fields: [rowId], references: [id], onDelete: Cascade)
  rowId String

  price Int
  order Int @default(0)

  customerPrices TariffCellCustomerPrice[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("tariff_cell")
}

model TariffCellCustomerPrice {
  id String @id @default(cuid())

  cell   TariffCell @relation(fields: [cellId], references: [id])
  cellId String

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String

  price Int

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([cellId, customerId])
  @@map("tariff_cell_customer_price")
}
