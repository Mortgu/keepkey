model Order {
  id String @id @default(uuid())

  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  supplierId String? // Lieferanten-Nr.

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String // Kunden-Nr.

  customerContactPerson ContactPerson @relation(fields: [contactPersonId], references: [id])
  contactPersonId       String // Ihr Ansprechpartner

  employee   User   @relation(fields: [employeeId], references: [id])
  employeeId String // Unser Ansprechpartner

  offer   Offer  @relation(fields: [offerId], references: [id])
  offerId String @unique // One-to-one relation

  orderId     String // Beleg-Nr.
  paymentTerm String @default("") // Zahlungsbedingung

  date        DateTime  @default(now()) // Datum
  validUntil  DateTime?
  requestFrom DateTime?

  net_amount Int

  orderPositions OrderPosition[]
  flatRates      OrderFlatRate[]
  orderDocuments OrderDocument[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("order")
}

model OrderPosition {
  id String @id @default(uuid())

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  product   Product @relation(fields: [productId], references: [id])
  productId String

  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String

  duration_months Int
  quantity        Int

  optional Boolean? @default(false)

  total_cents Int

  createdAt DateTime @default(now())

  @@map("order_position")
}

model OrderFlatRate {
  id String @id @default(uuid())

  flatRate   FlatRate @relation(fields: [flatRateId], references: [id])
  flatRateId String

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  quantity    Int
  total_cents Int

  @@map("order_flat_rate")
}

model OrderDocument {
  id String @id @default(uuid())

  version   Int
  isCurrent Boolean @default(false)

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  documentId String   @unique

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  @@unique([orderId, version, documentId])
  @@map("order_documents")
}
