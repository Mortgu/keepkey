model Order {
  id String @id @default(uuid())

  orderId     String // Beleg-Nr.
  date        DateTime @default(now()) // Datum
  paymentTerm String   @default("") // Zahlungsbedingung
  projectId   String // Projekt-Nr.

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String // Kunden-Nr.

  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  supplierId String? // Lieferanten-Nr.

  offer   Offer  @relation(fields: [offerId], references: [id])
  offerId String @unique // One-to-one relation

  customerContactPerson ContactPerson @relation(fields: [contactPersonId], references: [id])
  contactPersonId       String // Ihr Ansprechpartner

  employee   User   @relation(fields: [employeeId], references: [id])
  employeeId String // Unser Ansprechpartner

  orderPositions OrderPosition[]

  // Fehlt: Summe Netto EUR, MwSt. 19.00%, Summe Brutto EUR

  documents Document[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @default(now())

  @@map("order")
}

model OrderPosition {
  id String @id @default(uuid())

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  product   Product @relation(fields: [productId], references: [id])
  productId String

  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String

  duration_months Int
  quantity        Int

  unit_price Int
  discount   Int
  total      Int

  createdAt DateTime @default(now())

  @@map("order_position")
}
