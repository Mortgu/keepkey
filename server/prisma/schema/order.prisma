model Order {
  id String @id @default(uuid())

  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  supplierId String? // Lieferanten-Nr.

  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String // Kunden-Nr.

  customerContactPerson ContactPerson @relation(fields: [contactPersonId], references: [id])
  contactPersonId       String // Ihr Ansprechpartner

  employee   User   @relation(fields: [employeeId], references: [id])
  employeeId String // Unser Ansprechpartner

  offer   Offer  @relation(fields: [offerId], references: [id])
  offerId String @unique // One-to-one relation

  orderId         String // Beleg-Nr.
  /// @openapi.ignore
  documentVersion Int    @default(0)
  paymentTerm     String @default("") // Zahlungsbedingung

  projectNumber      String? // Projekt-Nr.
  projectDescription String? // Projektbezug
  orderDetails       String? // Bestelldetails (Registrierung, Absprachen etc.)

  date        DateTime  @default(now()) // Datum
  validUntil  DateTime?
  requestFrom DateTime?

  net_amount Int

  version Int @default(1)

  documents      OrderDocument[]
  orderPositions OrderPosition[]
  flatRates      OrderFlatRate[]
  revisions      OrderRevision[]

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("order")
}

model OrderRevision {
  id String @id @default(uuid())

  version         Int
  snapshotVersion Int  @default(1)
  snapshot        Json

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  changedBy   User   @relation(fields: [changedById], references: [id])
  changedById String

  createdAt DateTime @default(now())

  @@unique([orderId, version])
  @@map("order_revision")
}

model OrderPosition {
  id String @id @default(uuid())

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  product   Product @relation(fields: [productId], references: [id])
  productId String

  contract   Contract @relation(fields: [contractId], references: [id])
  contractId String

  duration_months Int
  quantity        Int

  optional Boolean? @default(false)

  total_cents Int

  createdAt DateTime @default(now())

  @@map("order_position")
}

model OrderFlatRate {
  id String @id @default(uuid())

  flatRate   FlatRate @relation(fields: [flatRateId], references: [id])
  flatRateId String

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  quantity    Int
  total_cents Int

  @@map("order_flat_rate")
}

model OrderDocument {
  id String @id @default(cuid())

  displayName   String?
  version       Int            @default(0)
  sourceVersion Int?
  status        DocumentStatus
  isCurrent     Boolean        @default(false)

  error       String?
  /// @openapi.ignore
  uploadToken String?

  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId String

  pdf   Document? @relation(name: "orderPdf", fields: [pdfId], references: [id], onDelete: Cascade)
  pdfId String?   @unique

  docx   Document? @relation(name: "orderDocx", fields: [docxId], references: [id], onDelete: Cascade)
  docxId String?   @unique

  task   Task   @relation(fields: [taskId], references: [id])
  taskId String @unique

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@unique([orderId, version])
  @@map("order_document")
}
