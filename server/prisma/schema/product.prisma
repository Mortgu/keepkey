model Product {
  id  String @id @default(uuid())
  key String @unique // sprachunabhängiger Identifier (ersetzt das bisherige @unique auf name)

  translations ProductTranslation[]

  orderPositions OrderPosition[]
  offerPositions OfferPosition[]

  tariff   Tariff? @relation(fields: [tariffId], references: [id], onDelete: SetNull)
  tariffId String?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  tariffCustomers TariffCustomer[]

  @@index([tariffId])
  @@map("product")
}

model ProductTranslation {
  productId String
  language  Language

  name        String
  description String?
  table       String?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, language])
  @@index([language, name])
  @@map("product_translation")
}
