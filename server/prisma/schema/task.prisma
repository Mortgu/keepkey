enum TaskStatus {
  COMPLETED
  RUNNING
  PENDING
  FAILED
}

enum TaskTarget {
  OFFER
  ORDER
  RENEWAL
}

enum TaskType {
  UPLOAD
  RESERVATION
  GENERATION
}

model Task {
  id    String  @id @default(cuid())
  jobId String?

  status TaskStatus @default(PENDING)
  target TaskTarget
  type   TaskType

  error String?

  document         Document? @relation("DocumentTask")
  offerReservation Offer?    @relation("OfferReservationTask")

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  @@map("task")
}
