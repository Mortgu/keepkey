enum TaskStatus {
  COMPLETED
  RUNNING
  PENDING
  FAILED
}

enum TaskTarget {
  OFFER
  ORDER
  RENEWAL
  INVOICE
}

enum TaskType {
  UPLOAD
  RESERVATION
  GENERATION
}

model Task {
  id    String  @id @default(cuid())
  jobId String?
  /// @openapi.ignore
  runToken String?

  status TaskStatus @default(PENDING)
  target TaskTarget
  type   TaskType

  error String?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  offerDocuments OfferDocument[]
  orderDocuments OrderDocument[]

  @@map("task")
}
