model Customer {
  id String @id @default(uuid())

  customerId  String?
  companyName String

  email        String? @unique
  invoiceEmail String?
  phone        String?

  street String?
  city   String?
  zip    String?

  language Language @default(DE)
  country  String   @default("Deutschland")
  currency Currency @default(EUR)
  taxRate  Float    @default(0)

  salutation String?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  contactPersons ContactPerson[]

  offers Offer[]
  orders Order[]

  users       User[]
  tariffCells TariffCellCustomer[]

  @@map("customer")
}

model ContactPerson {
  id String @id @default(uuid())

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  salutation String?
  email      String?

  firstName String
  lastName  String

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  offers Offer[]
  orders Order[]

  @@unique([id, customerId])
  @@index([customerId])
  @@map("contact_person")
}
