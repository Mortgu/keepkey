model Customer {
  id String @id @default(uuid())

  customerId  String  @unique
  companyName String
  email       String? @unique

  street String?
  city   String?
  plz    String?
  phone  String?

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  contactPersons ContactPerson[]

  offers Offer[]
  orders Order[]

  users           User[]
  tariffCustomers TariffCustomer[]

  @@map("customer")
}

model ContactPerson {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  salutation String
  firstName  String
  lastName   String
  email      String?
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @db.Timestamptz(6)

  offers Offer[]
  orders Order[]

  @@index([customerId])
  @@map("contact_person")
}
