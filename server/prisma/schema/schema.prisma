generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

generator openapi {
  provider = "prisma-openapi"
  output   = "./openapi"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  salutation    String
  firstName     String
  lastName      String
  phone         String?   @default("")
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  sessions      Session[]
  accounts      Account[]

  role       String?
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?
  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?
  offers     Offer[]
  orders     Order[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  impersonatedBy String?

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime?

  @@index([identifier])
  @@map("verification")
}

model Supplier {
  id String @id @default(uuid())

  supplierId String
  name       String

  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  offers Offer[]
  orders Order[]

  @@map("supplier")
}

model FlatRate {
  id          String @id @default(uuid())
  name        String
  table       String
  total_cents Int

  offerFlatRates OfferFlatRate[]
  orderFlatRates OrderFlatRate[]

  @@map("flat_rate")
}

model Contract {
  id String @id @default(uuid())

  name     String
  features String[]

  table String @default("")

  orderPositions OrderPosition[]
  offerPositions OfferPosition[]

  tariffConfigs   TariffConfig[]
  tariffCustomers TariffCustomer[]

  createdAt DateTime? @default(now())

  @@map("contract")
}

enum Language {
  DE
  EN
}
